{
	"name": "MastroGPT",
	"image":"mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {},
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.12",
			"installTools": true,
			"toolsToInstall": "virtualenv"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22",
			"nodeGypDependencies": true
		},
		"./features/ops-install": {}
	},
	"containerEnv": {
		"OPS_BRANCH": "main"
	},
	"remoteEnv": {
		"OPS_BRANCH": "main"
	},
	"runArgs": [
		"--network=host"
	],
	"postCreateCommand": "~/.local/bin/ops -update ; /usr/local/python/current/bin/python -m pip install -r ${containerWorkspaceFolder}/requirements.txt",
	"customizations": {
		"vscode": {
			"extensions": [
				"pgant.antonio-ops-vscode-extension@1.3.2",
				"ms-python.python",
				"pamaron.pytest-runner",
				"marp-team.marp-vscode",
				"ryuta46.multi-command",
				"george-alisson.html-preview-vscode",
				"mathematic.vscode-pdf",
				"ms-vscode.test-adapter-converter"
			]
		}
	}
}